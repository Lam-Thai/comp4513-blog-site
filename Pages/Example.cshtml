@page
@using System.Dynamic
@model ExampleModel
@{
    var message = "Hello from Razor Pages!";
}

<h1>Example Page</h1>

<p>Hello, @Model.Name</p>

<p>Today is @Model.</p>

<form action="">
    <label for="inputField">Enter your name:</label>
    <input type="text" id="inputField" name="name" />
    <button type="submit">Submit</button>
</form>

<p>Message: @message</p>

@{
    List<string> words = new List<string> { "Hello", "from", "Razor", "Pages!" };
}

@foreach (var word in words)
{
    <span>@word</span>
}